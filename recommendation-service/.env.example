# DB アクセス（候補取得・ログ書込）。service_role は秘密鍵。サーバ側のみに置く。
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 認証（option 2）。
# クライアントの Supabase ログイントークン(JWT)を検証するための公開鍵。
# ＝ アプリの EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY と同じ値でよい（公開鍵なので秘密ではない）。
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# /retrain（再学習）を保護する管理者キー。任意のランダム文字列を自分で決める。
#   例: openssl rand -hex 16
# 未設定なら /retrain は 503 で無効化される。
ADMIN_API_KEY=

# /recommend・/feedback に JWT を必須化する（既定 true＝secure-by-default）。
# ローカル検証で認証を切りたい時のみ明示的に false にする（本番は true 推奨）。
RECOMMENDATION_REQUIRE_AUTH=true

# CORS 許可オリジンの allowlist（カンマ区切り）。空ならブラウザ越しのクロスオリジンは一切許可しない。
# ワイルドカード "*" は credentials と併用できないため使用不可。明示オリジンのみ列挙する。
#   例: RECOMMENDATION_CORS_ORIGINS=http://localhost:8081,https://app.example.com
RECOMMENDATION_CORS_ORIGINS=

MODEL_PATH=models/model.joblib
DEFAULT_RADIUS_M=2000
DEFAULT_TOP_K=5
DEFAULT_CAPACITY=3
APP_TIMEZONE=Asia/Tokyo

# 自前 API 保護層（in-process）。
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_BURST=10
CACHE_TTL_SECONDS=30
# 信頼できる前段プロキシ(LB等)配下でのみ true。true だと X-Forwarded-For を
# クライアントIPとして採用する。直公開なら false 推奨（false=ソケットIP=詐称不可）。
TRUST_FORWARDED_FOR=false
