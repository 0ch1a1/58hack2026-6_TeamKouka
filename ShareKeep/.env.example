# ShareKeep 環境変数テンプレート。
# このファイルをコピーして `.env` を作成し、実値を入れること（.env は gitignore 対象）。
#   cp .env.example .env
#
# 値は Supabase ダッシュボード > Project Settings > API から取得。
# ※ ANON_KEY ではなく PUBLISHABLE_KEY を使う（lib/supabase.ts が参照）。

EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# scripts/seed-agents.ts / scripts/unseed-agents.ts 用。
# service_role key は本番 DB を直接変更できるため、クライアントには絶対に渡さない。
SUPABASE_URL=https://zbmrmblakoszzecdnptn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
