# ShareKeep 環境変数テンプレート。
# このファイルをコピーして `.env` を作成し、実値を入れること（.env は gitignore 対象）。
#   cp .env.example .env
#
# 値は Supabase ダッシュボード > Project Settings > API から取得。
# ※ ANON_KEY ではなく PUBLISHABLE_KEY を使う（lib/supabase.ts が参照）。

EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# scripts/seed-agents.ts / scripts/unseed-agents.ts 用。
# service_role key は本番 DB を直接変更できるため、クライアントには絶対に渡さない。
SUPABASE_URL=https://zbmrmblakoszzecdnptn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# 推薦スコアリングサービス（recommendation-service）のデプロイ URL。
# 受取人の中間者選択画面が候補をスコア順で取得するのに使う（features/recommend.ts）。
# 未設定でもアプリは動く（既存の自動マッチ matchNearbyAgent にフォールバック）。
# 例: https://sharekeep-reco.onrender.com / http://192.168.x.x:8000（実機ローカル検証時）
EXPO_PUBLIC_RECOMMENDATION_URL=

# デモ用 delivery_company_id（受取人の荷物登録に使う固定 UUID / lib/config.ts が参照）。
# 未設定ならコード内のデモ既定 UUID にフォールバックする。DB 再作成で seed が変わったら新 ID をここで指定。
EXPO_PUBLIC_DEMO_DELIVERY_COMPANY_ID=
